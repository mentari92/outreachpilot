# OutreachPilot — Environment Variables Reference
# ================================================
# NOTE: Chrome Extensions do not use .env files at runtime.
# API keys are entered by the user via the Settings page
# and stored in chrome.storage.sync.
#
# This file is for reference only — to document what keys are needed.
# ================================================

# -------------------------------------
# LLM API KEYS (enter via Settings page)
# At least ONE key is required to use the extension.
# The extension auto-falls back to the next available provider.
# -------------------------------------

# Google Gemini API Key
# Get it at: https://aistudio.google.com/app/apikey
# Free tier available
GEMINI_API_KEY=AIza...

# Anthropic Claude API Key
# Get it at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# OpenAI API Key
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Groq API Key (fast & free tier available)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter API Key (access all models with 1 key)
# Get it at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# -------------------------------------
# GOOGLE SHEETS (enter via Settings page)
# Required for Story 5.1 — Google Sheets Logger
# -------------------------------------

# Your Google Sheets ID
# Found in the URL: docs.google.com/spreadsheets/d/[SHEETS_ID]/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Google API Key (for Sheets API v4)
# Get it at: https://console.cloud.google.com/
# Enable: Google Sheets API
GOOGLE_API_KEY=AIza...

# -------------------------------------
# USER PREFERENCES (enter via Settings page)
# -------------------------------------

# Your name (used in generated outreach emails)
USER_NAME=Your Name

# Your email signature (used in generated emails)
USER_SIGNATURE=Best regards,\nYour Name\nCanva Link Building Team

# Default LLM model to use
# Options: gemini | claude | openai | groq | openrouter
DEFAULT_MODEL=gemini
